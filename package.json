{
	"name": "06.1.fimi-tech-backend",
	"version": "0.0.1",
	"description": "",
	"author": "",
	"private": true,
	"license": "UNLICENSED",
	"scripts": {
		"build": "nest build",
		"format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
		"start": "dotenv -e .env.development -- nest start",
		"start:dev": "dotenv -e .env.development --  nest start --watch",
		"start:debug": "nest start --debug --watch",
		"start:prod": "node dist/main",
		"lint": "eslint . --fix",
		"test": "jest",
		"test:watch": "jest --watch",
		"test:cov": "jest --coverage",
		"test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
		"test:e2e": "jest --config ./test/jest-e2e.json",
		"prepare": "husky",
		"commitlint": "commitlint --edit",
		"lint-staged": "lint-staged",
		"docker:dev": "docker compose --env-file ./.env.development -f docker-compose.dev.yml up -d",
		"docker:build": "docker build -t fimi_admin_backend .",
		"docker:dev:config": "docker compose --env-file ./.env.development -f docker-compose.dev.yml config",
		"docker:dev:remove": "docker compose --env-file ./.env.development -f docker-compose.dev.yml down",
		"prisma:migrate": "dotenv -e .env.development -- npx prisma migrate",
		"prisma:push": "dotenv -e .env.development -- npx prisma db push",
		"prisma:generate": "dotenv -e .env.development -- npx prisma generate",
		"prisma:studio": "dotenv -e .env.development -- npx prisma studio",
		"prisma:seed": "dotenv -e .env.development -- node prisma/seed"
	},
	"dependencies": {
		"@nestjs-modules/mailer": "^2.0.2",
		"@nestjs/bullmq": "^10.2.3",
		"@nestjs/common": "10.4.15",
		"@nestjs/config": "3.3.0",
		"@nestjs/core": "10.4.15",
		"@nestjs/event-emitter": "^2.1.1",
		"@nestjs/jwt": "^10.2.0",
		"@nestjs/mapped-types": "*",
		"@nestjs/platform-express": "10.4.15",
		"@nestjs/swagger": "^8.1.1",
		"@prisma/client": "^6.2.1",
		"argon2": "^0.41.1",
		"bullmq": "^5.34.10",
		"googleapis": "^144.0.0",
		"nodemailer": "^6.9.16",
		"otp-generator": "^4.0.1",
		"reflect-metadata": "0.2.2",
		"rxjs": "7.8.1",
		"winston": "3.17.0",
		"winston-daily-rotate-file": "5.0.0"
	},
	"devDependencies": {
		"@commitlint/cli": "19.6.0",
		"@commitlint/config-conventional": "19.6.0",
		"@eslint/js": "9.18.0",
		"@nestjs/cli": "10.4.9",
		"@nestjs/schematics": "10.2.3",
		"@nestjs/testing": "10.4.15",
		"@types/express": "5.0.0",
		"@types/jest": "29.5.14",
		"@types/node": "22.10.6",
		"@types/nodemailer": "^6.4.17",
		"@types/otp-generator": "^4.0.2",
		"@types/supertest": "6.0.2",
		"class-transformer": "^0.5.1",
		"class-validator": "^0.14.1",
		"dotenv-cli": "^8.0.0",
		"eslint": "9.18.0",
		"eslint-config-prettier": "10.0.1",
		"eslint-plugin-import": "2.31.0",
		"eslint-plugin-prettier": "5.2.1",
		"eslint-plugin-simple-import-sort": "12.1.1",
		"globals": "15.14.0",
		"husky": "9.1.7",
		"jest": "29.7.0",
		"lint-staged": "15.3.0",
		"prettier": "3.4.2",
		"prisma": "^6.2.1",
		"source-map-support": "0.5.21",
		"supertest": "7.0.0",
		"ts-jest": "29.2.5",
		"ts-loader": "9.5.2",
		"ts-node": "10.9.2",
		"tsconfig-paths": "4.2.0",
		"typescript": "5.7.3",
		"typescript-eslint": "8.20.0"
	},
	"jest": {
		"moduleFileExtensions": [
			"js",
			"json",
			"ts"
		],
		"moduleNameMapper": {
			"@/(.*)$": "<rootDir>/$1"
		},
		"rootDir": "src",
		"testRegex": ".*\\.spec\\.ts$",
		"transform": {
			".+\\.(t|j)s$": "ts-jest"
		},
		"collectCoverageFrom": [
			"**/*.(t|j)s"
		],
		"coverageDirectory": "../coverage",
		"testEnvironment": "node"
	},
	"lint-staged": {
		"*.ts": [
			"npm run lint",
			"npm run format",
			"git add ."
		]
	}
}
