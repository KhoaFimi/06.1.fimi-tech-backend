generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

// #region:Enum
enum GENDER {
  MALE
  FEMALE
}

// #endregion

// #region:Common Type
type Image {
  key String
  url String
}

// #endregion

// #region:User
model User {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId
  code          String    @unique @map("pub_code")
  fullname      String
  phone         String    @unique
  email         String    @unique
  emailVerified DateTime? @map("email_verified")
  password      String    @unique
  roles         Int       @default(0) //0: pub/am, 1:partner, >=2: admin
  document      Document?
  profile       Profile?
  tnc           Boolean   @default(false)
  partnerId     String    @db.ObjectId
  partner       Partner   @relation(fields: [partnerId], references: [id])
  managerId     String?   @db.ObjectId
  manager       User?     @relation("manage", fields: [managerId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  manage        User[]    @relation("manage")
  createdAt     DateTime  @default(now())
  isDelete      Boolean   @default(false)
  updatedAt     DateTime  @updatedAt
  refreshToken  String?

  @@map("user")
}

type Profile {
  dateOfBirth    DateTime? @map("date_of_birth")
  placeOfBirth   String?   @map("place_of_birth")
  gender         GENDER?
  avatar         Image?
  workAt         String?   @map("work_at")
  currentAddress Address?
  bank           Bank?
}

type Address {
  detail   String?
  ward     String?
  district String?
  province String?
}

type Bank {
  accountName   String? @map("account_name")
  accountNumber String? @map("account_number")
  name          String?
}

type Document {
  citizenIdentification String?   @map("citizen_identification")
  dateOfIssue           DateTime? @map("date_of_issue")
  placeOfIssue          DateTime? @map("place_of_issue")
  imageFront            Image?    @map("image_front")
  imageBack             Image?    @map("image_back")
  potrait               Image?
  spec                  Json?
}

// #endregion

// #region: Partner
model Partner {
  id         String      @id @default(auto()) @map("_id") @db.ObjectId
  code       String      @unique
  publsihers User[]
  prize      PricePolicy
  apiKey     String
  isDelete   Boolean     @default(false)
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  @@map("partners")
}

type PricePolicy {
  origin Float  @default(0.95)
  am     Float?
  pub    Float?
}

// #endregion

// #region: Tolken
model VerificationToken {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  identifier String
  expires    DateTime
  token      String   @unique

  @@map("verfication_tokens")
}

model ResetPasswordToken {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  identifier String
  expires    DateTime
  token      String   @unique

  @@map("reset_password_tokens")
}

// #endregion

// #region: Campaign & Category
enum CampaignStatus {
  UNVERIFY
  OPEN
  CLOSE
}

type CampaignOffer {
  title   String
  summary String
  offers  String[]
}

type CampaignRequirement {
  minAge    Int
  maxAge    Int?
  documents String[]
}

type CampaignInfo {
  supportArea     String[] @default(["all"])
  approveTime     String
  finalResultTime String
}

type CampaignSpec {
  title       String
  description String[]
}

type CampaignCommissionPolicy {
  orderStatus String   @default("Phê duyệt")
  description String
  commissions String[]
  note        String?
}

type CampaignRecognitionRules {
  summary     String
  description String[]
  note        String?
}

model Campaign {
  id                  String                    @id @default(auto()) @map("_id") @db.ObjectId
  code                String                    @unique
  status              CampaignStatus            @default(UNVERIFY)
  name                String
  advertiser          String?
  link                String?
  categoryId          String                    @db.ObjectId
  category            Category                  @relation(fields: [categoryId], references: [id])
  images              Image[]
  video               String?
  offers              CampaignOffer[]
  info                CampaignInfo?
  specs               CampaignSpec[]
  requirement         CampaignRequirement?
  commissionPolicy    CampaignCommissionPolicy?
  recognitionRules    CampaignRecognitionRules?
  registrationProcess String[]                  @default([])
  rejectReason        String[]                  @default([])
  unqualifiedRecords  String[]                  @default([])
  createdAt           DateTime                  @default(now())
  updatedAt           DateTime                  @updatedAt

  @@map("campaigns")
}

model Category {
  id        String     @id @default(auto()) @map("_id") @db.ObjectId
  name      String     @unique
  campaigns Campaign[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@map("categories")
}

// #endregion
